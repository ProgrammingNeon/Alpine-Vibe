# Залежності проекту (папки з бібліотеками)
node_modules/
bower_components/
vendor/
.venv/
env/

# Логи та тимчасові файли
*.log
*.tmp
*.bak
npm-debug.log*
yarn-debug.log*

# Конфігурації середовища та секрети (паролі, ключі API)
.env
.env.local
.env.production
*.pem
*.key

# Системні файли операційних систем
.DS_Store
Thumbs.db
desktop.ini

# Файли збірки та компіляції
dist/
build/
out/
*.exe
*.dll

# Налаштування редакторів коду та IDE
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln

# Кеш та тимчасові файли Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
